PORT=5000
# Comma-separated Vite dev URLs (add 5174 if 5173 is taken by another app)
# CLIENT_URL=http://localhost:5173,http://localhost:5174
# Comma-separated if Vite uses another port (e.g. 5174 when 5173 is busy)
CLIENT_URL=http://localhost:5173,http://localhost:5174
# Local MongoDB (easiest for dev):
MONGO_URI=mongodb://127.0.0.1:27017/aangan
# Atlas: URL-encode special characters in the password (@ → %40, etc.)
JWT_SECRET=change_me_to_a_long_random_string
ADMIN_EMAIL=admin@aangan.com
ADMIN_PASSWORD=change_me
